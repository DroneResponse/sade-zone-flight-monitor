# SADE Flight Monitor — environment variable template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values for
# your deployment.  The app reads env vars directly at startup; you do not
# need a process manager or docker-compose to load them — any standard method
# works (direct export, `docker run -e`, ECS task definition env, etc.).
#
# Rules of thumb:
#   * Lines ending in `# REQUIRED` must be set for the relevant mode to work.
#   * Lines ending in `# optional` have sensible defaults; leave unset if fine.
#   * `# REQUIRED-FOR-AWS` = required only when running against AWS IoT Core.
#   * `# REQUIRED-FOR-FINALIZATION` = required only when FINALIZE_TO_API=true.

# ── MQTT broker ──────────────────────────────────────────────────────────────
# For local testing point at a Mosquitto broker; for production point at the
# AWS IoT Core ATS endpoint (port 8883, TLS required).
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=update_drone
MQTT_TLS_ENABLED=false

# ── MQTT auth (username/password brokers only — NOT AWS IoT Core) ───────────
# Leave unset for AWS IoT Core (which uses mTLS instead).  Populate only for
# managed brokers like HiveMQ Cloud that authenticate with username/password
# over TLS.
#MQTT_USERNAME=
#MQTT_PASSWORD=

# ── MQTT mTLS (AWS IoT Core) ─────────────────────────────────────────────────
# Required when connecting to AWS IoT Core.  All three cert paths must be set
# together; set none of them for non-mTLS brokers.  Paths point at files that
# must exist on the filesystem (or be bind-mounted into the container at
# /certs via `docker run -v /host/sade-certs:/certs:ro`).
#
# The files themselves MUST NEVER be committed — see .gitignore.
#MQTT_CA_CERT_PATH=/certs/CAs.crt                # REQUIRED-FOR-AWS
#MQTT_CLIENT_CERT_PATH=/certs/client.crt         # REQUIRED-FOR-AWS
#MQTT_PRIVATE_KEY_PATH=/certs/client.key         # REQUIRED-FOR-AWS

# Stable MQTT client identifier.  AWS IoT Core policies restrict which client
# IDs a given cert may use — paho's random default will be silently rejected
# and the MQTT CONNECT will hang with no error logged.  Pick a value your
# IoT policy allows.  Only one connection may use a given ID at a time.
#MQTT_CLIENT_ID=sade-flight-monitor              # REQUIRED-FOR-AWS

# ── Session source ───────────────────────────────────────────────────────────
# `aws`   — pipeline only accepts telemetry for sessions pre-registered via
#           POST /flight-monitor/register-session (the production behaviour).
# `local` — pipeline auto-creates synthetic sessions for any drone that
#           publishes (useful for smoke tests without the webhook).
SESSION_SOURCE_MODE=aws

# ── SADE finalization callback (outbound HTTP to SADE AWS) ───────────────────
# When FINALIZE_TO_API=true the pipeline POSTs one finalization report per
# completed session to TRACKER_FINALIZED_URL.  The URL is REQUIRED in that
# mode — the pipeline fails fast at startup if it's unset — so the same
# container image can be promoted across environments without code changes.
FINALIZE_TO_API=true
#TRACKER_FINALIZED_URL=http://your-sade-host.example.com/tracker-session-finalized   # REQUIRED-FOR-FINALIZATION

# ── Output ───────────────────────────────────────────────────────────────────
# Path for the finalized-mission CSV.  Empty disables CSV output.  In a
# container this path must be inside a mounted volume for the file to survive.
MISSION_ROWS_OUT=

# ── Pipeline tuning ──────────────────────────────────────────────────────────
# Defaults are fine for moderate load (~100 drones at 10 msg/s); see the 75-
# drone stress test in scripts/run_stress_test.py for guidance on scaling.
WORKER_COUNT=1                      # optional
QUEUE_SIZE=10000                    # optional
SHUTDOWN_TIMEOUT=10                 # optional (seconds)
IDLE_WARNING_SECONDS=300            # optional — warn when no MQTT messages arrive
METRICS_LOG_INTERVAL=30             # optional (seconds)
MEMORY_SAMPLE_INTERVAL=0            # optional — 0 disables RSS sampling

# ── FastAPI webhook server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
