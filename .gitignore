# Python runtime artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment
venv/
.venv/
env/

# Test and debug output
local_test_output/
mission_rows.csv
*.log
.pytest_cache/

# PKI material — never commit certificates, private keys, or signing requests.
# Certs for AWS IoT Core (and anything similar) should live outside the repo
# and be mounted into the container at runtime.
*.key
*.crt
*.csr
*.pem
*.pfx
*.p12

# Deployment env files — `.env.example` IS committed (it's a template with
# placeholder values), but any real `.env` file with filled-in secrets must
# never be committed.
.env
.env.local
.env.*.local

# Claude Code project config
.claude/

# Editor and OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo
local_testing/api-certs/
